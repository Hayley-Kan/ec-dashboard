<script>
// ================================================================
// ★ GAS URL（デプロイ後に入力）
// ================================================================
const GAS_URL = 'https://script.google.com/macros/s/AKfycbwUt_k-UVsjAX03ysZgBTaw9JjIDUtqSp_3CgxcymRz8ExjLt5R0FuMZPaOM2_AF-Uy/exec';
// ================================================================

const S = { store: null, month: null, fileId: '', fileName: '', compass: null, ledger: null };
const charts = {};

// ── 初期化（直列実行）──────────────────────────────────────────
async function init() {
  try {
    // 1. 店舗一覧
    loading('店舗情報を取得中...');
    const stores = await api('stores');
    if (!stores.length) throw new Error('店舗データが取得できません');

    const ss = document.getElementById('sel-store');
    ss.innerHTML = stores.map(s => `<option value="${s.id}">${s.label}</option>`).join('');
    S.store = stores[0].id;
    setLogoFromStore(stores[0]);
    updateTabVisibility();

    // 2. 月一覧
    loading('月一覧を取得中...');
    const months = await api('months');
    const sm = document.getElementById('sel-month');
    // months配列をSTATEに保持
    S.monthsData = months;
    if (months.length) {
      sm.innerHTML = months.map(m =>
        `<option value="${m.month}" data-fileid="${m.fileId||''}" data-filename="${m.fileName||''}">${m.label}</option>`
      ).join('');
      S.month    = months[0].month;
      S.fileId   = months[0].fileId   || '';
      S.fileName = months[0].fileName || '';
    } else {
      sm.innerHTML = '<option value="">月データなし</option>';
    }

    // 3. 羅盤データ
    if (S.month) {
      loading('羅盤データを取得中...');
      await loadCompass();
    }

    // 4. 帳簿データ
    loading('帳簿データを取得中...');
    await loadLedger();

  } catch(e) {
    showErr(e.message);
  } finally {
    hideLoading();
  }
}

// ── データ取得 ─────────────────────────────────────────────────
async function loadCompass() {
  const sheetName = S.store ? S.store.split('_')[0] : 'Fujiko';
  const data = await api('compass', { month: S.month, sheet: sheetName });
  if (data.error) throw new Error('羅盤: ' + data.error);
  S.compass = data;
  renderCompass(data);
}

async function loadLedger() {
  if (!S.store) return;
  const data = await api('ledger', { store: S.store });
  if (data.error) throw new Error('帳簿: ' + data.error);
  S.ledger = data;
  renderLedger(data);
}

// ── イベント ───────────────────────────────────────────────────
async function onStoreChange() {
  S.store = document.getElementById('sel-store').value;
  updateTabVisibility();
  loading('データ更新中...');
  try {
    if (!isRedStore()) await loadCompass();
    await loadLedger();
  } catch(e) { showErr(e.message); } finally { hideLoading(); }
}

async function onMonthChange() {
  const opt = document.getElementById('sel-month').selectedOptions[0];
  S.month    = opt.value;
  S.fileId   = opt.dataset.fileid   || '';
  S.fileName = opt.dataset.filename || '';
  loading('羅盤データ更新中...');
  try { await loadCompass(); } catch(e) { showErr(e.message); } finally { hideLoading(); }
}

async function reloadAll() {
  loading('再読み込み中...');
  try { if (!isRedStore()) await loadCompass(); await loadLedger(); }
  catch(e) { showErr(e.message); } finally { hideLoading(); }
}

function isRedStore() {
  return S.store && S.store.includes('RED');
}

function updateTabVisibility() {
  const compassTab = document.querySelector('.tab[onclick*="compass"]');
  if (compassTab) compassTab.style.display = isRedStore() ? 'none' : '';
  if (isRedStore() && document.getElementById('tab-compass').classList.contains('active')) {
    switchTab('ledger');
  }
}

function switchTab(name) {
  document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('active', ['compass','ledger'][i] === name));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
}



// ── 羅盤レンダリング ───────────────────────────────────────────
function renderCompass(d) {
  const s = d.summary;
  const roasCls = s.roas >= 3 ? 'b-good' : s.roas >= 2 ? 'b-warn' : 'b-bad';
  const feeCls  = s.feeRatio <= 0.3 ? 'b-good' : s.feeRatio <= 0.4 ? 'b-warn' : 'b-bad';

  // ポップアップ用に現在値・ファイルURLをキャッシュ
  KPI_CURRENT.gmv      = fmtN(s.gmv) + ' RMB';
  KPI_CURRENT.settle   = fmtN(s.settle) + ' RMB';
  KPI_CURRENT.invest   = fmtN(s.invest) + ' RMB';
  KPI_CURRENT.feeRatio = pct(s.feeRatio);
  KPI_CURRENT.roas     = s.roas.toFixed(2) + 'x';
  KPI_CURRENT.refund   = pct(s.avgRefund);
  // 羅盤ファイルのURL（Google Sheetsとして開く）
  KPI_CURRENT.compassUrl      = S.fileId ? `https://docs.google.com/spreadsheets/d/${S.fileId}/edit` : '';
  KPI_CURRENT.compassFileName = S.fileName || ('収支分析' + (S.month||''));

  document.getElementById('compass-kpi').innerHTML = `
    <div class="kpi"><button class="kpi-help-btn" onclick="showKpiPopup('gmv')">?</button><div class="kpi-label">GMV（成交金額）</div><div class="kpi-val num" style="color:var(--brand)">${fmtN(s.gmv)}</div><div class="kpi-sub">月次合計 RMB</div></div>
    <div class="kpi"><button class="kpi-help-btn" onclick="showKpiPopup('settle')">?</button><div class="kpi-label">決済金額</div><div class="kpi-val num" style="color:var(--text)">${fmtN(s.settle)}</div><div class="kpi-sub">結算金額</div></div>
    <div class="kpi"><button class="kpi-help-btn" onclick="showKpiPopup('invest')">?</button><div class="kpi-label">投放消耗（広告費）</div><div class="kpi-val num" style="color:var(--text)">${fmtN(s.invest)}</div><div class="kpi-sub">月次合計</div></div>
    <div class="kpi"><button class="kpi-help-btn" onclick="showKpiPopup('feeRatio')">?</button><div class="kpi-label">総合費比</div><div class="kpi-val ${feeCls}">${pct(s.feeRatio)}</div><div class="kpi-sub">目標 ≤30%</div></div>
    <div class="kpi"><button class="kpi-help-btn" onclick="showKpiPopup('roas')">?</button><div class="kpi-label">総合ROAS</div><div class="kpi-val ${roasCls}">${s.roas.toFixed(2)}x</div><div class="kpi-sub">目標 ≥3.0x</div></div>
    <div class="kpi"><button class="kpi-help-btn" onclick="showKpiPopup('refund')">?</button><div class="kpi-label">平均退款率</div><div class="kpi-val ${s.avgRefund<=0.1?'b-good':s.avgRefund<=0.2?'b-warn':'b-bad'}">${pct(s.avgRefund)}</div><div class="kpi-sub">月次平均</div></div>
  `;

  // 日次チャート
  const labels = d.daily.map(r => r.date.slice(5));
  mkBarLine('c-daily-gmv', labels,
    [{ label:'GMV', data:d.daily.map(r=>r.gmv), bg:'rgba(192,0,0,.18)', border:'#C00000' },
     { label:'投放消耗', data:d.daily.map(r=>r.invest), bg:'rgba(26,86,160,.25)', border:'#1A56A0' }]);
  mkLine('c-daily-roas', labels,
    [{ label:'ROAS', data:d.daily.map(r=>+r.roas.toFixed(2)), color:'#EA580C' }],
    { refLine: 3, refLabel:'目標3.0x' });

  // ── チャネル比較 ──
  const chs = d.channels.filter(ch => ch.invest > 0); // 広告費ありのみ
  const COLORS = ['#C00000','#1A56A0','#EA580C','#8B5E00','#534AB7'];

  // ROASバー
  const maxRoas = Math.max(...chs.map(c=>c.roas), 3) * 1.1;
  document.getElementById('ch-roas-bars').innerHTML = chs.map((ch,i) => `
    <div class="ch-bar-row">
      <div class="ch-bar-label">${ch.name}</div>
      <div class="ch-bar-track"><div class="ch-bar-fill" style="width:${(ch.roas/maxRoas*100).toFixed(1)}%;background:${COLORS[i%COLORS.length]}"></div></div>
      <div class="ch-bar-val" style="color:${ch.roas>=3?'var(--green)':ch.roas>=2?'var(--yellow)':'var(--red)'}">${ch.roas.toFixed(2)}x</div>
    </div>
  `).join('') + `<div class="ch-bar-row"><div class="ch-bar-label" style="color:var(--text3)">目標3.0x</div>
    <div class="ch-bar-track"><div class="ch-bar-fill" style="width:${(3/maxRoas*100).toFixed(1)}%;background:var(--red);opacity:.5"></div></div>
    <div class="ch-bar-val" style="color:var(--text3)">3.00x</div></div>`;

  // 費比バー
  const maxFee = Math.max(...chs.map(c=>c.feeRatio), 0.3) * 1.1;
  document.getElementById('ch-fee-bars').innerHTML = chs.map((ch,i) => `
    <div class="ch-bar-row">
      <div class="ch-bar-label">${ch.name}</div>
      <div class="ch-bar-track"><div class="ch-bar-fill" style="width:${(ch.feeRatio/maxFee*100).toFixed(1)}%;background:${COLORS[i%COLORS.length]}"></div></div>
      <div class="ch-bar-val" style="color:${ch.feeRatio<=0.3?'var(--green)':ch.feeRatio<=0.4?'var(--yellow)':'var(--red)'}">${pct(ch.feeRatio)}</div>
    </div>
  `).join('') + `<div class="ch-bar-row"><div class="ch-bar-label" style="color:var(--text3)">目標30%</div>
    <div class="ch-bar-track"><div class="ch-bar-fill" style="width:${(0.3/maxFee*100).toFixed(1)}%;background:var(--green);opacity:.4"></div></div>
    <div class="ch-bar-val" style="color:var(--text3)">30.0%</div></div>`;

  // GMV構成比ドーナツ
  mkDonut('c-ch-gmv-pie',
    chs.map(c=>c.name), chs.map(c=>Math.round(c.gmv)), COLORS);

  // 広告費構成比ドーナツ
  mkDonut('c-ch-spend-pie',
    chs.map(c=>c.name), chs.map(c=>Math.round(c.invest)), COLORS);

  // ROAS・費比比較棒グラフ（grouped）
  mkGroupedBar('c-ch-compare', chs.map(c=>c.name), [
    { label:'ROAS', data:chs.map(c=>+c.roas.toFixed(2)), bg:'rgba(192,0,0,.6)', border:'#C00000', yAxisID:'yRoas' },
    { label:'費比(%)', data:chs.map(c=>+(c.feeRatio*100).toFixed(1)), bg:'rgba(26,86,160,.55)', border:'#1A56A0', yAxisID:'yFee' },
  ], { refLine:3 });

  // チャネル詳細テーブル
  const totalGmv = d.channels.reduce((a,c)=>a+c.gmv,0)||1;
  const totalAd  = d.channels.reduce((a,c)=>a+c.invest,0)||1;
  document.getElementById('ch-tbody').innerHTML = d.channels.map(ch => {
    const rc = ch.roas>=3?'b-good':ch.roas>=2?'b-warn':'b-bad';
    const bl = ch.roas>=3?'badge-good':ch.roas>=2?'badge-warn':'badge-bad';
    const bt = ch.invest===0?'広告なし':ch.roas>=3?'目標達成':ch.roas>=2?'要改善':'未達成';
    return `<tr>
      <td>${ch.name}</td>
      <td class="num">${fmtN(ch.gmv)}</td><td class="num">${fmtN(ch.settle)}</td>
      <td class="num">${fmtN(ch.invest)}</td>
      <td class="${rc} num">${ch.invest>0?ch.roas.toFixed(2)+'x':'—'}</td>
      <td>${ch.invest>0?pct(ch.feeRatio):'—'}</td>
      <td>${pct(ch.gmv/totalGmv)}</td>
      <td>${ch.invest>0?pct(ch.invest/totalAd):'—'}</td>
      <td><span class="badge ${bl}">${bt}</span></td>
    </tr>`;
  }).join('');
  document.getElementById('ch-tfoot').innerHTML = `<tr>
    <td>合計</td><td class="num">${fmtN(s.gmv)}</td><td class="num">${fmtN(s.settle)}</td>
    <td class="num">${fmtN(s.invest)}</td>
    <td class="${s.roas>=3?'b-good':s.roas>=2?'b-warn':'b-bad'} num">${s.roas.toFixed(2)}x</td>
    <td>${pct(s.feeRatio)}</td><td>100%</td><td>100%</td><td></td>
  </tr>`;

  // 週次集計テーブル
  const weekly = [];
  d.daily.forEach(r => {
    const dt = new Date(r.date);
    const day = dt.getDay(); // 0=日
    // 月曜始まりの週番号
    const mon = new Date(dt); mon.setDate(dt.getDate() - ((day+6)%7));
    const wkey = mon.toISOString().slice(0,10);
    let w = weekly.find(x=>x.key===wkey);
    if (!w) { w={key:wkey,start:r.date,end:r.date,gmv:0,settle:0,invest:0,refundSum:0,days:0}; weekly.push(w); }
    w.end=r.date; w.gmv+=r.gmv; w.settle+=r.settle; w.invest+=r.invest;
    w.refundSum+=r.refund; w.days++;
  });
  document.getElementById('daily-tbody').innerHTML = weekly.map((w,i) => {
    const roas = w.invest>0 ? w.gmv/w.invest : 0;
    const feeR = w.gmv>0 ? w.invest/w.gmv : 0;
    const refund = w.days>0 ? w.refundSum/w.days : 0;
    const rc = roas>=3?'b-good':roas>=2?'b-warn':'b-bad';
    const start = w.start.slice(5); const end = w.end.slice(5);
    return `<tr>
      <td>W${i+1}</td>
      <td style="color:var(--text3);font-size:11px">${start}〜${end}</td>
      <td class="num">${fmtN(w.gmv)}</td><td class="num">${fmtN(w.settle)}</td>
      <td class="num">${fmtN(w.invest)}</td>
      <td class="${rc} num">${roas>0?roas.toFixed(2)+'x':'—'}</td>
      <td>${pct(feeR)}</td><td>${pct(refund)}</td>
    </tr>`;
  }).join('');
}

// ── 帳簿レンダリング (案B) ──────────────────────────────────────
function renderLedger(d) {
  if (!d.rows || d.rows.length === 0) {
    document.getElementById('ledger-kpi').innerHTML = '<div class="b-kpi"><div class="b-kpi-val">データなし</div></div>';
    return;
  }
  const rows = d.rows;
  const latest = rows[rows.length - 1];

  // ── KPI ──
  const gmCls = (latest.grossMargin||0)>=0.35?'b-good':(latest.grossMargin||0)>=0.2?'b-warn':'b-bad';
  const opCls = (latest.opMargin||0)>=0.1?'b-good':(latest.opMargin||0)>=0?'b-warn':'b-bad';
  document.getElementById('ledger-kpi').innerHTML = `
    <div class="b-kpi"><div class="b-kpi-label">売上合計</div><div class="b-kpi-val num" style="color:#C00000">${fmtV(latest.sales)}</div><div class="b-kpi-sub">${latest.month} / RMB</div></div>
    <div class="b-kpi"><div class="b-kpi-label">原価合計</div><div class="b-kpi-val num" style="color:#3D3D3B">${fmtV(latest.cogs)}</div><div class="b-kpi-sub">売上比 ${latest.sales>0?pct(v(latest.cogs)/latest.sales):'—'}</div></div>
    <div class="b-kpi"><div class="b-kpi-label">粗利</div><div class="b-kpi-val num" style="color:#C00000">${fmtV(latest.grossProfit)}</div><div class="b-kpi-sub">粗利率 ${latest.grossMargin!=null?pct(latest.grossMargin):'—'}</div></div>
    <div class="b-kpi"><div class="b-kpi-label">費用合計</div><div class="b-kpi-val num" style="color:#3D3D3B">${fmtV(latest.expense)}</div><div class="b-kpi-sub">売上比 ${latest.sales>0?pct(v(latest.expense)/latest.sales):'—'}</div></div>
    <div class="b-kpi"><div class="b-kpi-label">営業利益</div><div class="b-kpi-val num" style="${latest.opProfit>=0?'color:#C00000':'color:#C00000'}">${fmtV(latest.opProfit)}</div><div class="b-kpi-sub">利益率 ${latest.opMargin!=null?pct(latest.opMargin):'—'}</div></div>
  `;

  const sl = v(latest.sales);
  const gp = v(latest.grossProfit);
  const op = v(latest.opProfit);

  // ── ウォーターフォール（SVGバー）──
  const wfItems = [
    { name:'売上',     val: sl,                 color:'#C00000', offset: 0,               width: sl },
    { name:'原価',     val:-v(latest.cogs),     color:'#5A5A58', offset: gp,              width: v(latest.cogs) },
    { name:'粗利',     val: gp,                 color:'#C00000', offset: 0,               width: gp },
    { name:'費用',     val:-v(latest.expense),  color:'#5A5A58', offset:Math.max(op,0),   width: v(latest.expense) },
    { name:'営業利益', val: op,                 color:'#C00000', offset:0,                width:Math.abs(op) },
  ];
  // 縦ウォーターフォール（Chart.js floating bar）
  mkWaterfall('c-wf-chart',
    wfItems.map(i=>i.name),
    wfItems.map(i=>[Math.min(i.offset, i.offset+i.width*(i.val>=0?1:-1)), Math.max(i.offset, i.offset+i.width*(i.val>=0?1:-1))]),
    wfItems.map(i=>i.color)
  );

  // ── 統合ドーナツ（原価＋費用） ──
  const COLORS_COGS_DONUT = ['#C00000','#E57373','#1A56A0','#60A5FA','#1B6B3A','#6EE7B7','#8B5E00'];
  const COLORS_EXP_DONUT  = ['#534AB7','#8B7FDE','#C4C0F0'];
  const cogsItems = [
    ['商品原価（買取）', latest.cogsBuy],
    ['商品原価（委託）', latest.cogsConst],
    ['サンプル／景品',   latest.sample],
    ['FEE',             latest.fee],
    ['ライブ原価',       latest.liveCost],
    ['リスティング',     latest.listing],
    ['その他販促費',     latest.otherPromo],
  ].filter(([,val]) => val != null && val > 0);
  const expItems = [
    ['運営人件費', latest.staffCost],
    ['CS',         latest.cs],
    ['ライブ人件費', latest.liveSatff],
  ].filter(([,val]) => val != null && val > 0);

  // 内側：原価合計 vs 費用合計
  const innerLabels = ['原価合計', '費用合計'];
  const innerData   = [Math.round(v(latest.cogs)), Math.round(v(latest.expense))];
  const innerColors = ['#5A5A58', '#534AB7'];

  // 外側：各詳細項目
  const outerLabels = [...cogsItems.map(([n])=>n), ...expItems.map(([n])=>n)];
  const outerData   = [...cogsItems.map(([,vv])=>Math.round(vv)), ...expItems.map(([,vv])=>Math.round(vv))];
  const outerColors = [...COLORS_COGS_DONUT.slice(0, cogsItems.length), ...COLORS_EXP_DONUT.slice(0, expItems.length)];

  mkDoubleDonut('c-combined-donut', innerLabels, innerData, innerColors, outerLabels, outerData, outerColors);

  // 凡例
  const legendEl = document.getElementById('b-donut-legend');
  legendEl.innerHTML =
    '<div style="font-size:9px;font-weight:500;color:#b4b2a9;letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px;padding-bottom:3px;border-bottom:0.5px solid #e0ddd5">原価</div>' +
    cogsItems.map(([name, val], i) =>
      `<div class="b-legend-item"><div class="b-legend-dot" style="background:${COLORS_COGS_DONUT[i]}"></div><span style="flex:1">${name}</span><span style="color:#5F5E5A;font-variant-numeric:tabular-nums">${sl>0?pct(val/sl):'—'}</span></div>`
    ).join('') +
    '<div style="font-size:9px;font-weight:500;color:#b4b2a9;letter-spacing:.08em;text-transform:uppercase;margin:6px 0 4px;padding-bottom:3px;border-bottom:0.5px solid #e0ddd5">費用</div>' +
    expItems.map(([name, val], i) =>
      `<div class="b-legend-item"><div class="b-legend-dot" style="background:${COLORS_EXP_DONUT[i]}"></div><span style="flex:1">${name}</span><span style="color:#5F5E5A;font-variant-numeric:tabular-nums">${sl>0?pct(val/sl):'—'}</span></div>`
    ).join('');

  // ── 月次損益明細（202603〜202702） ──
  const plRows = [
    { label:'売上合計',          key:'sales',       cls:'b-total' },
    { label:'原価合計',          key:'cogs',        cls:'b-total' },
    { label:'商品原価（買取）',   key:'cogsBuy',     cls:'b-sub' },
    { label:'商品原価（委託）',   key:'cogsConst',   cls:'b-sub' },
    { label:'サンプル／景品',     key:'sample',      cls:'b-sub' },
    { label:'FEE',               key:'fee',         cls:'b-sub' },
    { label:'ライブ原価',         key:'liveCost',    cls:'b-sub' },
    { label:'リスティング',       key:'listing',     cls:'b-sub' },
    { label:'その他販促費',       key:'otherPromo',  cls:'b-sub' },
    { label:'粗利',               key:'grossProfit', cls:'b-grand', pct:'grossMargin' },
    { label:'費用合計',           key:'expense',     cls:'b-total' },
    { label:'運営人件費',         key:'staffCost',   cls:'b-sub' },
    { label:'CS',                 key:'cs',          cls:'b-sub' },
    { label:'ライブ人件費',       key:'liveSatff',   cls:'b-sub' },
    { label:'営業利益',           key:'opProfit',    cls:'b-grand', pct:'opMargin' },
  ];

  // 全月（202603〜202702）をカバー
  const ALL_MONTHS = ['202603','202604','202605','202606','202607','202608','202609','202610','202611','202612','202701','202702'];
  const rowMap = {};
  rows.forEach(r => { rowMap[r.month] = r; });

  document.getElementById('pl-thead').innerHTML =
    '<th style="text-align:left;min-width:110px">項目</th>' +
    ALL_MONTHS.map(m => `<th style="min-width:76px">${m}</th>`).join('') +
    '<th style="min-width:80px;background:#FEF0F0;color:#C00000;border-left:2px solid #C00000">年度合計</th>';

  document.getElementById('pl-tbody').innerHTML = plRows.map(def => {
    const anyData = ALL_MONTHS.some(m => rowMap[m] && rowMap[m][def.key] != null && rowMap[m][def.key] !== 0);
    if (!anyData && def.cls === 'b-sub') return '';
    const cells = ALL_MONTHS.map(m => {
      const r = rowMap[m];
      const val = r ? r[def.key] : null;
      if (val == null || val === '') return `<td class="b-dim">—</td>`;
      let cls = '';
      if (def.cls === 'b-grand') cls = val >= 0 ? 'b-val-pos' : 'b-val-neg';
      if (def.pct && r) {
        const p = r[def.pct];
        const pctCls = def.key==='grossProfit'
          ? (p>=0.35?'b-good':p>=0.2?'b-warn':'b-bad')
          : (p>=0.1?'b-good':p>=0?'b-warn':'b-bad');
        return `<td class="${cls} num">${fmtV(val)}<br><span style="font-size:9px" class="${pctCls}">${pct(p)}</span></td>`;
      }
      return `<td class="${cls} num">${fmtV(val)}</td>`;
    }).join('');

    // 年度合計列
    let yearTotal = '';
    if (def.pct && def.key !== 'grossProfit' && def.key !== 'opProfit') {
      // 純粋な比率行（粗利率・営業利益率など）は合計不要
      yearTotal = '<td style="background:#FEF0F0;border-left:2px solid #C00000" class="b-dim">—</td>';
    } else {
      const sum = ALL_MONTHS.reduce((acc, m) => {
        const r = rowMap[m];
        return acc + (r && r[def.key] != null ? (r[def.key] || 0) : 0);
      }, 0);
      const hasSomeData = ALL_MONTHS.some(m => rowMap[m] && rowMap[m][def.key] != null && rowMap[m][def.key] !== 0);
      if (!hasSomeData) {
        yearTotal = '<td style="background:#FEF0F0;border-left:2px solid #C00000" class="b-dim">—</td>';
      } else {
        const cls = def.cls==='b-grand' ? (sum>=0?'b-val-pos':'b-val-neg') : '';
        yearTotal = `<td style="background:#FEF0F0;border-left:2px solid #C00000;font-weight:600" class="${cls} num">${fmtV(sum)}</td>`;
      }
    }

    const tdFirst = def.cls === 'b-sub'
      ? `<td style="padding-left:16px;color:#888780;font-size:11px">${def.label}</td>`
      : `<td>${def.label}</td>`;
    return `<tr class="${def.cls}">${tdFirst}${cells}${yearTotal}</tr>`;
  }).join('');

  // ── 内訳数値テーブル（3列目）──
  const cogsTotal = cogsItems.reduce((a,[,vv])=>a+(vv||0),0)||1;
  const expTotal  = expItems.reduce((a,[,vv])=>a+(vv||0),0)||1;
  // ドーナツと同じ色配列を使用
  const COLORS_COGS = COLORS_COGS_DONUT;
  const COLORS_EXPD = COLORS_EXP_DONUT;

  const mkRow = (name, val, pctSales, pctInner, color) =>
    `<div style="display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:0.5px solid #F2F0EC">
       <div style="width:8px;height:8px;border-radius:2px;background:${color};flex-shrink:0"></div>
       <span style="flex:1;font-size:10px;color:#4A4845">${name}</span>
       <span style="font-size:10px;font-variant-numeric:tabular-nums;color:#1A1A18;font-weight:500">${fmtV(val)}</span>
       <span style="font-size:10px;color:#888480;min-width:36px;text-align:right">${pctSales}</span>
     </div>`;

  let breakdownHtml =
    `<div style="font-size:9px;font-weight:600;color:#BAB8B3;letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px">原価</div>` +
    cogsItems.map(([name,val],i) => mkRow(name, val, sl>0?pct(val/sl):'—', pct(val/cogsTotal), COLORS_COGS[i%COLORS_COGS.length])).join('') +
    `<div style="font-size:9px;font-weight:600;color:#BAB8B3;letter-spacing:.08em;text-transform:uppercase;margin:8px 0 4px">費用</div>` +
    expItems.map(([name,val],i) => mkRow(name, val, sl>0?pct(val/sl):'—', pct(val/expTotal), COLORS_EXPD[i%COLORS_EXPD.length])).join('');

  const bdEl = document.getElementById('b-breakdown-table');
  if (bdEl) bdEl.innerHTML = breakdownHtml;

  // 旧テーブルも更新（残っている場合）
  const cogsTbody = document.getElementById('cogs-tbody');
  if (cogsTbody) cogsTbody.innerHTML = cogsItems.map(([name,val]) =>
    `<tr><td>${name}</td><td class="num">${fmtV(val)}</td><td>${sl>0?pct(val/sl):'—'}</td><td>${pct(val/cogsTotal)}</td></tr>`
  ).join('') || '<tr><td colspan="4" style="color:#b4b2a9;text-align:center;padding:10px">データなし</td></tr>';
  const expTbody = document.getElementById('exp-tbody');
  if (expTbody) expTbody.innerHTML = expItems.map(([name,val]) =>
    `<tr><td>${name}</td><td class="num">${fmtV(val)}</td><td>${sl>0?pct(val/sl):'—'}</td><td>${pct(val/expTotal)}</td></tr>`
  ).join('') || '<tr><td colspan="4" style="color:#b4b2a9;text-align:center;padding:10px">データなし</td></tr>';
}

