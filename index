<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FindJapan 越境EC運営レポート</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chartjs-plugin-datalabels/2.2.0/chartjs-plugin-datalabels.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  /* Brand */
  --brand:#C00000;--brand-light:#FAEAEA;--brand-mid:#E57373;
  /* Neutral */
  --bg:#F8F7F5;--bg2:#FFFFFF;--bg3:#F2F0EC;--border:#E4E1DA;--border2:#CCC8BF;
  --text:#1A1A18;--text2:#4A4845;--text3:#888480;--text4:#BAB8B3;
  /* Semantic */
  --c-pos:#1B6B3A;--c-pos-bg:#EBF5EE;
  --c-warn:#8B5E00;--c-warn-bg:#FEF6E4;
  --c-neg:#B91C1C;--c-neg-bg:#FEF2F2;
  --c-blue:#1A56A0;--c-blue-bg:#EFF6FF;
  --radius:10px;
}
body{font-family:'Hiragino Kaku Gothic ProN','Noto Sans JP',sans-serif;
  background:var(--bg);color:var(--text);min-height:100vh;font-size:13px;line-height:1.5}

/* ── ヘッダー ── */
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;background:#fff;
  border-bottom:2px solid var(--brand);
  gap:12px;flex-wrap:wrap;position:sticky;top:0;z-index:100;height:56px;
}
.logo{display:flex;align-items:center;gap:12px}
.logo-mark{
  width:34px;height:34px;border-radius:8px;background:var(--brand);
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:700;color:#fff;flex-shrink:0;letter-spacing:-.3px;
}
.logo-title{font-size:14px;font-weight:600;color:var(--text);letter-spacing:-.01em}
.logo-sub{font-size:11px;color:var(--text3);margin-top:1px}
.controls{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
select,button{
  font-size:12px;padding:5px 12px;border-radius:6px;
  border:1px solid var(--border2);background:#fff;color:var(--text);
  cursor:pointer;font-family:inherit;transition:all .15s;
}
select:hover,button:hover{border-color:var(--brand);box-shadow:0 0 0 2px var(--brand-light)}
select:focus{outline:none;border-color:var(--brand)}
.cur-label{
  padding:4px 10px;font-size:11px;border-radius:4px;
  background:var(--brand-light);color:var(--brand);font-weight:500;border:none;
}

/* ── タブ ── */
.tabs{
  display:flex;gap:6px;background:#fff;
  border-bottom:1px solid var(--border);padding:10px 28px;align-items:center;
}
.tab{
  padding:6px 18px;font-size:12px;font-weight:500;color:var(--text3);
  border:1px solid transparent;background:none;cursor:pointer;
  border-radius:20px;transition:all .15s;font-family:inherit;
}
.tab:hover{color:var(--text);background:var(--bg3);border-color:var(--border)}
.tab.active{
  color:#fff;background:var(--brand);border-color:var(--brand);
  box-shadow:0 2px 8px rgba(192,0,0,.2);
}

/* ── メイン ── */
.main{padding:22px 28px;background:var(--bg);min-height:calc(100vh - 56px)}
.tab-content{display:none}
.tab-content.active{display:block}

/* ── KPIカード（共通） ── */
.kpi-row,.b-kpi-row{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));
  gap:10px;margin-bottom:18px;
}
.kpi,.b-kpi{
  background:#fff;border:1px solid var(--border);border-radius:var(--radius);
  padding:14px 16px;transition:all .15s;position:relative;overflow:hidden;
}
.kpi::before,.b-kpi::before{
  content:'';position:absolute;top:0;left:0;width:3px;height:100%;
  background:var(--border2);transition:background .15s;
}
.kpi:hover,.b-kpi:hover{border-color:var(--brand);box-shadow:0 2px 10px rgba(192,0,0,.08)}
.kpi:hover::before,.b-kpi:hover::before{background:var(--brand)}
.kpi-label,.b-kpi-label{font-size:11px;color:var(--text3);margin-bottom:6px;font-weight:400}
.kpi-val,.b-kpi-val{font-size:22px;font-weight:600;letter-spacing:-.03em}
.kpi-sub,.b-kpi-sub{font-size:11px;color:var(--text4);margin-top:4px}

/* ── カード ── */
.row2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}
.b-row2{display:grid;grid-template-columns:3fr 2fr;gap:14px;margin-bottom:14px}
@media(max-width:860px){.row2,.row3,.b-row2{grid-template-columns:1fr}}
.card,.b-card{
  background:#fff;border:1px solid var(--border);border-radius:var(--radius);padding:16px;
}
.card-title,.b-card-title{
  font-size:10px;font-weight:600;color:var(--text3);
  letter-spacing:.08em;text-transform:uppercase;margin-bottom:12px;
}
.chart-h180{position:relative;height:180px}
.chart-h200{position:relative;height:200px}
.chart-h240{position:relative;height:240px}
.chart-h280{position:relative;height:280px}

/* ── テーブル共通 ── */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
thead th{
  padding:8px 10px;text-align:right;font-size:10px;font-weight:600;color:var(--text3);
  border-bottom:2px solid var(--border);white-space:nowrap;
  background:var(--bg3);
}
thead th:first-child{text-align:left}
tbody tr{border-bottom:1px solid var(--bg3)}
tbody tr:hover{background:#FAFAF8}
tbody td{padding:7px 10px;text-align:right;white-space:nowrap;color:var(--text)}
tbody td:first-child{text-align:left;color:var(--text2)}
tfoot td{padding:8px 10px;text-align:right;font-weight:600;
  border-top:2px solid var(--border2);background:var(--bg3)}
tfoot td:first-child{text-align:left}
.num{font-variant-numeric:tabular-nums}
.dim{color:var(--text4)}

/* ── バッジ ── */
.badge{font-size:10px;padding:2px 8px;border-radius:4px;font-weight:500;white-space:nowrap}
.badge-good{background:var(--c-pos-bg);color:var(--c-pos)}
.badge-warn{background:var(--c-warn-bg);color:var(--c-warn)}
.badge-bad{background:var(--c-neg-bg);color:var(--c-neg)}

/* ── セマンティックカラー ── */
.good,.b-good{color:var(--c-pos)}.warn,.b-warn{color:var(--c-warn)}.bad,.b-bad{color:var(--c-neg)}
.b-val-pos{color:var(--c-pos)}.b-val-neg{color:var(--c-neg)}.b-dim{color:var(--text4)}

/* ── セクション区切り ── */
.section{
  font-size:10px;font-weight:600;color:var(--text4);letter-spacing:.1em;text-transform:uppercase;
  margin:20px 0 8px;padding-bottom:5px;border-bottom:1px solid var(--border);
}

/* ── チャネル比較バー ── */
.ch-bar-wrap{display:flex;flex-direction:column;gap:9px;padding:4px 0}
.ch-bar-row{display:grid;grid-template-columns:90px 1fr 60px;align-items:center;gap:8px}
.ch-bar-label{font-size:11px;color:var(--text2);text-align:right}
.ch-bar-track{height:8px;background:var(--bg3);border-radius:4px;overflow:hidden}
.ch-bar-fill{height:100%;border-radius:4px;transition:width .5s ease}
.ch-bar-val{font-size:11px;font-weight:600;text-align:right}

/* ── ウォーターフォール ── */
.b-wf{display:flex;flex-direction:column;gap:7px}
.b-wf-row{display:flex;align-items:center;gap:8px}
.b-wf-name{font-size:11px;color:var(--text2);width:72px;text-align:right;flex-shrink:0}
.b-wf-track{flex:1;height:13px;background:var(--bg3);border-radius:3px;position:relative;overflow:hidden}
.b-wf-fill{height:100%;border-radius:3px;position:absolute}
.b-wf-val{font-size:11px;width:64px;text-align:right;flex-shrink:0;font-variant-numeric:tabular-nums;font-weight:600}

/* ── 統合ドーナツ ── */
.b-legend{display:flex;flex-direction:column;gap:4px;flex:1}
.b-legend-item{display:flex;align-items:center;gap:6px;font-size:10px;color:var(--text2);width:100%}
.b-legend-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0}
.b-legend-sep{font-size:9px;font-weight:600;color:var(--text4);letter-spacing:.06em;text-transform:uppercase;
  margin:4px 0 3px;padding-top:4px;border-top:1px solid var(--border)}

/* ── 損益明細テーブル ── */
.b-pl-table{width:100%;border-collapse:collapse;font-size:12px}
.b-pl-table th{padding:8px 10px;font-size:10px;font-weight:600;color:var(--text3);
  border-bottom:2px solid var(--border);white-space:nowrap;text-align:right;background:var(--bg3)}
.b-pl-table th:first-child{text-align:left}
.b-pl-table td{padding:5px 10px;text-align:right;font-variant-numeric:tabular-nums;
  white-space:nowrap;border-bottom:1px solid var(--bg3)}
.b-pl-table td:first-child{text-align:left;color:var(--text2)}
.b-pl-table tr.b-sub td:first-child{padding-left:20px;color:var(--text3);font-size:11px}
.b-pl-table tr.b-total td{font-weight:600;color:var(--text);background:#FAFAF8;border-bottom:1px solid var(--border)}
.b-pl-table tr.b-grand td{font-weight:600;background:var(--bg3);
  border-top:2px solid var(--border2);border-bottom:2px solid var(--border2)}
.b-pl-table tr:hover td{background:#FEF9F9}

/* ── 内訳テーブル ── */
.b-detail-tbl{width:100%;border-collapse:collapse;font-size:11px}
.b-detail-tbl th{padding:6px 8px;font-size:10px;font-weight:600;color:var(--text3);
  border-bottom:2px solid var(--border);text-align:right;background:var(--bg3)}
.b-detail-tbl th:first-child{text-align:left}
.b-detail-tbl td{padding:5px 8px;text-align:right;font-variant-numeric:tabular-nums;
  border-bottom:1px solid var(--bg3);color:var(--text)}
.b-detail-tbl td:first-child{text-align:left;color:var(--text2)}

/* ── ローディング ── */
#overlay{
  position:fixed;inset:0;background:rgba(248,247,245,.92);
  display:flex;align-items:center;justify-content:center;
  z-index:9999;flex-direction:column;gap:14px;transition:opacity .25s;
}
#overlay.hidden{opacity:0;pointer-events:none}
.spin{width:28px;height:28px;border:2.5px solid var(--border2);
  border-top-color:var(--brand);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.load-msg{color:var(--text3);font-size:12px}

/* ── エラー ── */
.err{background:var(--c-neg-bg);border:1px solid var(--c-neg);border-radius:8px;
  padding:10px 14px;color:var(--c-neg);font-size:12px;margin-bottom:14px;display:none}

/* ── KPI ヘルプボタン・ポップアップ ── */
.kpi-help-btn{
  position:absolute;top:9px;right:9px;
  width:17px;height:17px;border-radius:50%;
  background:var(--border2);color:var(--text3);
  font-size:10px;font-weight:700;line-height:17px;text-align:center;
  cursor:pointer;border:none;padding:0;font-family:inherit;
  transition:all .15s;flex-shrink:0;
}
.kpi-help-btn:hover{background:var(--brand);color:#fff}

/* overlay */
.kpi-popup-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.3);
  z-index:10000;display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;transition:opacity .2s;
}
.kpi-popup-overlay.show{opacity:1;pointer-events:all}

/* モーダル本体 */
.kpi-popup{
  background:#fff;border-radius:14px;
  width:100%;max-width:440px;max-height:88vh;overflow-y:auto;
  box-shadow:0 12px 48px rgba(0,0,0,.22);
  transform:translateY(10px);transition:transform .22s;
}
.kpi-popup-overlay.show .kpi-popup{transform:translateY(0)}

/* ヘッダー */
.kpi-popup-hdr{
  display:flex;align-items:flex-start;gap:12px;
  padding:20px 20px 16px;border-bottom:1px solid var(--border);
}
.kpi-popup-icon{
  width:36px;height:36px;border-radius:8px;background:var(--brand-light);
  display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;
}
.kpi-popup-hdr-text{flex:1}
.kpi-popup-title{font-size:15px;font-weight:600;color:var(--text);line-height:1.3}
.kpi-popup-subtitle{font-size:11px;color:var(--text3);margin-top:2px}
.kpi-popup-close{
  width:26px;height:26px;border-radius:50%;border:none;background:var(--bg3);
  color:var(--text2);font-size:13px;cursor:pointer;line-height:26px;text-align:center;
  transition:background .15s;flex-shrink:0;margin-top:2px;
}
.kpi-popup-close:hover{background:var(--brand);color:#fff}

/* 現在値バナー */
.kpi-popup-current{
  margin:14px 20px;padding:12px 16px;
  background:var(--brand-light);border-radius:8px;
  display:flex;align-items:center;justify-content:space-between;
}
.kpi-popup-current-label{font-size:11px;color:var(--brand);font-weight:500}
.kpi-popup-current-val{font-size:18px;font-weight:700;color:var(--brand);font-variant-numeric:tabular-nums}

/* セクション */
.kpi-popup-section{padding:0 20px 14px}
.kpi-popup-sec-title{
  font-size:10px;font-weight:600;color:var(--text4);letter-spacing:.08em;
  text-transform:uppercase;margin-bottom:8px;
  display:flex;align-items:center;gap:6px;
}
.kpi-popup-sec-title::before{
  content:'';display:inline-block;width:3px;height:12px;
  background:var(--brand);border-radius:2px;
}

/* データ出典カード */
.kpi-source-card{
  background:var(--bg3);border:1px solid var(--border);border-radius:8px;
  padding:10px 14px;margin-bottom:8px;
}
.kpi-source-card-title{font-size:12px;font-weight:600;color:var(--text);margin-bottom:6px;display:flex;align-items:center;gap:6px}
.kpi-source-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px}
.kpi-source-tag{
  font-size:10px;padding:2px 8px;border-radius:4px;font-weight:500;
  background:#E6F1FB;color:#185FA5;
}
.kpi-source-tag.cond{background:#FEF6E4;color:#8B5E00}
.kpi-source-tag.note{background:var(--border);color:var(--text2)}
.kpi-source-link{
  display:inline-flex;align-items:center;gap:4px;
  font-size:11px;color:var(--brand);text-decoration:none;
  padding:4px 10px;border:1px solid var(--brand-mid);border-radius:5px;
  transition:all .15s;background:#fff;
}
.kpi-source-link:hover{background:var(--brand);color:#fff;border-color:var(--brand)}

/* 計算式 */
.kpi-formula-block{
  background:#1A1A18;border-radius:8px;padding:14px 16px;
  font-family:'Courier New',monospace;font-size:12px;color:#E8E6E0;line-height:1.9;
}
.kpi-formula-block .hl{color:#FF8A80}
.kpi-formula-block .op{color:#80CBC4}
.kpi-formula-block .kw{color:#FFD54F}

/* 補足 */
.kpi-note-box{
  background:#FEF9F0;border:1px solid #F5D78A;border-radius:8px;
  padding:10px 14px;font-size:12px;color:#7A5A00;line-height:1.65;
  display:flex;gap:8px;
}
.kpi-note-box::before{content:'💡';flex-shrink:0}

/* フッター */
.kpi-popup-footer{
  padding:12px 20px;border-top:1px solid var(--border);
  font-size:11px;color:var(--text4);text-align:right;
}
</style>
</head>
<body>


<!-- KPI ヘルプポップアップ -->
<div class="kpi-popup-overlay" id="kpi-popup-overlay" onclick="closeKpiPopup(event)">
  <div class="kpi-popup">
    <!-- ヘッダー -->
    <div class="kpi-popup-hdr">
      <div class="kpi-popup-icon" id="kpi-popup-icon">📊</div>
      <div class="kpi-popup-hdr-text">
        <div class="kpi-popup-title" id="kpi-popup-title">—</div>
        <div class="kpi-popup-subtitle" id="kpi-popup-subtitle">—</div>
      </div>
      <button class="kpi-popup-close" onclick="document.getElementById('kpi-popup-overlay').classList.remove('show')">✕</button>
    </div>
    <!-- 現在値 -->
    <div class="kpi-popup-current">
      <div class="kpi-popup-current-label">現在値</div>
      <div class="kpi-popup-current-val" id="kpi-popup-current-val">—</div>
    </div>
    <!-- データ出典 -->
    <div class="kpi-popup-section">
      <div class="kpi-popup-sec-title">データ出典</div>
      <div id="kpi-popup-sources"></div>
    </div>
    <!-- 計算方法 -->
    <div class="kpi-popup-section">
      <div class="kpi-popup-sec-title">計算方法</div>
      <div class="kpi-formula-block" id="kpi-popup-formula"></div>
    </div>
    <!-- 補足 -->
    <div class="kpi-popup-section" id="kpi-popup-note-wrap">
      <div class="kpi-popup-sec-title">補足</div>
      <div class="kpi-note-box" id="kpi-popup-note"></div>
    </div>
    <div class="kpi-popup-footer">Douyin電商羅盤 データ基準</div>
  </div>
</div>
<div id="overlay">
  <div class="spin"></div>
  <div class="load-msg" id="load-msg">読み込み中...</div>
</div>

<div class="topbar">
  <div class="logo">
    <div class="logo-mark" id="logo-icon">FJ</div>
    <div>
      <div class="logo-title" id="logo-title">FindJapan 越境EC運営レポート</div>
      <div class="logo-sub" id="logo-sub" style="display:none"></div>
    </div>
  </div>
  <div class="controls">
    <select id="sel-store" onchange="onStoreChange()">
      <option value="">店舗を選択</option>
    </select>
    <select id="sel-month" onchange="onMonthChange()">
      <option value="">月を選択</option>
    </select>
    <span class="cur-label">RMB</span>
    <button onclick="reloadAll()">↻ 更新</button>
  </div>
</div>

<div class="tabs">
  <button class="tab active" onclick="switchTab('compass')">コンパス</button>
  <button class="tab"        onclick="switchTab('ledger')">月次報告</button>
</div>

<div class="main">
  <div class="err" id="err"></div>

  <!-- ===== 羅盤タブ ===== -->
  <div class="tab-content active" id="tab-compass">

    <div class="kpi-row" id="compass-kpi">
      <div class="kpi"><div class="kpi-label">GMV（成交金額）</div><div class="kpi-val dim">—</div></div>
      <div class="kpi"><div class="kpi-label">決済金額</div><div class="kpi-val dim">—</div></div>
      <div class="kpi"><div class="kpi-label">投放消耗（広告費）</div><div class="kpi-val dim">—</div></div>
      <div class="kpi"><div class="kpi-label">総合費比</div><div class="kpi-val dim">—</div></div>
      <div class="kpi"><div class="kpi-label">総合ROAS</div><div class="kpi-val dim">—</div></div>
      <div class="kpi"><div class="kpi-label">平均退款率</div><div class="kpi-val dim">—</div></div>
    </div>

    <div class="row2">
      <div class="card">
        <div class="card-title">日次 GMV・投放消耗 推移</div>
        <div class="chart-h200"><canvas id="c-daily-gmv"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">日次 ROAS 推移</div>
        <div class="chart-h200"><canvas id="c-daily-roas"></canvas></div>
      </div>
    </div>

    <div class="section">チャネル別比較分析</div>

    <div class="row3" style="margin-bottom:14px">
      <div class="card">
        <div class="card-title">ROAS 比較</div>
        <div id="ch-roas-bars" class="ch-bar-wrap"></div>
      </div>
      <div class="card">
        <div class="card-title">費比（ROI逆数）比較</div>
        <div id="ch-fee-bars" class="ch-bar-wrap"></div>
      </div>
      <div class="card">
        <div class="card-title">GMV 構成比</div>
        <div class="chart-h180"><canvas id="c-ch-gmv-pie"></canvas></div>
      </div>
    </div>

    <div class="row2" style="margin-bottom:14px">
      <div class="card">
        <div class="card-title">チャネル別 ROAS・費比チャート</div>
        <div class="chart-h240"><canvas id="c-ch-compare"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">チャネル別 投放消耗構成</div>
        <div class="chart-h240"><canvas id="c-ch-spend-pie"></canvas></div>
      </div>
    </div>

    <div class="card" style="margin-bottom:14px">
      <div class="card-title">チャネル別パフォーマンス詳細</div>
      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th>チャネル</th>
              <th>GMV</th><th>決済金額</th><th>投放消耗</th>
              <th>ROAS</th><th>費比</th>
              <th>GMV構成比</th><th>広告費構成比</th>
