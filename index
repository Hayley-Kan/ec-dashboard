function mkDoubleDonut(id, innerLabels, innerData, innerColors, outerLabels, outerData, outerColors) {
  const ctx = document.getElementById(id);
  const ex = Chart.getChart(ctx); if(ex) ex.destroy();
  const outerTotal = outerData.reduce((a,b)=>a+b,0)||1;
  const innerTotal = innerData.reduce((a,b)=>a+b,0)||1;

  // 外側ラベルの位置をスライスの外に出す
  new Chart(ctx, {
    type:'doughnut',
    plugins:[ChartDataLabels],
    data:{
      labels: [...innerLabels, ...outerLabels],
      datasets:[
        {
          // 内側：原価合計 vs 費用合計（太め・中心近く）
          label:'分類',
          data: innerData,
          backgroundColor: innerColors.map(c=>c+'ee'),
          borderColor:'#fff', borderWidth:4,
          cutout:'8%',
          radius:'54%',
        },
        {
          // 外側：詳細項目（太め・外周）
          label:'内訳',
          data: outerData,
          backgroundColor: outerColors.map(c=>c+'dd'),
          borderColor:'#fff', borderWidth:2,
          cutout:'56%',
          radius:'100%',
        }
      ]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      layout:{ padding:{ top:36, bottom:36, left:36, right:36 } },
      plugins:{
        legend:{ display:false },
        tooltip:{
          callbacks:{
            title:(items) => {
              const it = items[0];
              return it.datasetIndex===0 ? innerLabels[it.dataIndex] : outerLabels[it.dataIndex];
            },
            label:(item) => {
              const total = item.datasetIndex===0 ? innerTotal : outerTotal;
              return '  ' + Math.round(item.raw).toLocaleString('ja-JP') + ' RMB  (' + (item.raw/total*100).toFixed(1) + '%)';
            }
          }
        },
        datalabels:{
          display:(ctx) => {
            const total = ctx.datasetIndex===0 ? innerTotal : outerTotal;
            return (ctx.dataset.data[ctx.dataIndex]/total*100) >= 6;
          },
          color:(ctx) => ctx.datasetIndex===0 ? '#fff' : '#333',
          font:(ctx) => ({
            size: ctx.datasetIndex===0 ? 11 : 9,
            weight:'600'
          }),
          anchor:(ctx) => ctx.datasetIndex===0 ? 'center' : 'end',
          align:(ctx)  => ctx.datasetIndex===0 ? 'center' : 'end',
          offset:(ctx) => ctx.datasetIndex===0 ? 0 : 8,
          textAlign:'center',
          formatter:(val, ctx) => {
            const total = ctx.datasetIndex===0 ? innerTotal : outerTotal;
            const p = (val/total*100).toFixed(1);
            if (ctx.datasetIndex===0) {
              return innerLabels[ctx.dataIndex].replace('合計','') + '\n' + p + '%';
            }
            const name = outerLabels[ctx.dataIndex];
            return name.length > 6 ? name.slice(0,6)+'\n'+p+'%' : name+'\n'+p+'%';
          },
          clamp:true,
        }
      }
    }
  });
}

function mkDonut(id, labels, data, colors) {
  const ctx = document.getElementById(id);
  const ex = Chart.getChart(ctx); if(ex) ex.destroy();
  const total = data.reduce((a,b)=>a+b,0)||1;
  const showLabels = id === 'c-combined-donut';
  new Chart(ctx, {
    type:'doughnut',
    plugins: showLabels ? [ChartDataLabels] : [],
    data:{ labels, datasets:[{ data, backgroundColor:colors.map(c=>c+'dd'), borderColor:'#fff', borderWidth:2 }]},
    options:{
      responsive:true, maintainAspectRatio:false,
      cutout:'55%',
      plugins:{
        legend:{ display:false },
        tooltip:{ callbacks:{ label: ctx => ` ${ctx.label}: ${Math.round(ctx.raw).toLocaleString('ja-JP')} (${(ctx.raw/total*100).toFixed(1)}%)` } },
        datalabels: showLabels ? {
          color:'#fff',
          font:{ size:10, weight:'600' },
          formatter: (val) => {
            const p = val/total*100;
            return p >= 5 ? p.toFixed(1)+'%' : '';
          },
          anchor:'center',
          align:'center',
        } : { display: false }
      }
    }
  });
}

function mkWaterfall(id, labels, ranges, colors) {
  const ctx = document.getElementById(id);
  const ex = Chart.getChart(ctx); if(ex) ex.destroy();
  new Chart(ctx, {
    type:'bar',
    data:{
      labels,
      datasets:[{
        data: ranges.map(([lo,hi]) => [Math.min(lo,hi), Math.max(lo,hi)]),
        backgroundColor: colors.map(c => c+'cc'),
        borderColor: colors,
        borderWidth:1, borderRadius:3, borderSkipped:false,
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{
        legend:{ display:false },
        tooltip:{
          callbacks:{
            label: ctx => {
              const [lo,hi] = ctx.raw;
              return ` ${Math.round(hi-lo).toLocaleString('ja-JP')} RMB`;
            }
          }
        }
      },
      scales:{
        x:{ ticks:{ color:'#888480', font:{size:11} }, grid:{ color:'rgba(0,0,0,.04)' } },
        y:{ ticks:{ color:'#888480', font:{size:10}, callback:v=>Math.round(v/1000)+'K' }, grid:{ color:'rgba(0,0,0,.04)' } }
      }
    }
  });
}

function mkLine(id, labels, datasets, opts={}) {
  const ctx = document.getElementById(id);
  const ex = Chart.getChart(ctx); if(ex) ex.destroy();
  const dsets = datasets.map(ds => ({
    type:'line', label:ds.label, data:ds.data,
    borderColor:ds.color, backgroundColor:ds.color+'22',
    borderWidth:2, pointRadius:3, tension:.35, fill:true, spanGaps:true
  }));
  if(opts.refLine) dsets.push({
    type:'line', label:opts.refLabel||'目標',
    data:new Array(labels.length).fill(opts.refLine),
    borderColor:'#C00000', borderDash:[4,3], borderWidth:1.5,
    pointRadius:0, fill:false
  });
  const yTick = opts.yUnit ? { callback: v => v+opts.yUnit } : {};
  new Chart(ctx, {
    data:{ labels, datasets:dsets },
    options:{
      ...BASE_OPT,
      scales:{ ...BASE_OPT.scales, y:{ ...BASE_OPT.scales.y, ticks:{ ...BASE_OPT.scales.y.ticks, ...yTick } } }
    }
  });
}

