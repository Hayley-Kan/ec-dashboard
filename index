      <div class="b-kpi"><div class="b-kpi-label">粗利</div><div class="b-kpi-val">—</div></div>
      <div class="b-kpi"><div class="b-kpi-label">粗利率</div><div class="b-kpi-val">—</div><div class="b-kpi-sub">目標 35%</div></div>
      <div class="b-kpi"><div class="b-kpi-label">営業利益</div><div class="b-kpi-val">—</div></div>
      <div class="b-kpi"><div class="b-kpi-label">営業利益率</div><div class="b-kpi-val">—</div></div>
