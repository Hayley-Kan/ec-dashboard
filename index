    formula: '退款率 = 返品金額 ÷ GMV × 100%\n月次平均 = AVG(日次退款率)',
    note: '支払時間ベースと退款時間ベースで値が異なる場合あり。羅盤では両方表示されるため注意。'
  }
};

// 現在値キャッシュ（renderCompass時に更新）
const KPI_CURRENT = {};

function showKpiPopup(key) {
  const d = KPI_DEFS[key];
  if (!d) return;

  document.getElementById('kpi-popup-icon').textContent    = d.icon;
  document.getElementById('kpi-popup-title').textContent   = d.title;
  document.getElementById('kpi-popup-subtitle').textContent = d.subtitle;

  // 現在値
  const cv = KPI_CURRENT[key];
  document.getElementById('kpi-popup-current-val').textContent = cv ?? '—';

  // データ出典（羅盤ファイルは選択中のSSに直接リンク）
  const _ssUrl  = S.fileId
    ? 'https://docs.google.com/spreadsheets/d/' + S.fileId + '/edit'
    : COMPASS_FOLDER_URL;
  const _ssName = (S.fileName || ('収支分析' + (S.month||''))) + ' を開く';
  document.getElementById('kpi-popup-sources').innerHTML = d.sources.map(s => {
    const linkUrl   = s.useCompass ? _ssUrl  : s.url;
    const linkLabel = s.useCompass ? _ssName : s.urlLabel;
    return `
    <div class="kpi-source-card">
      <div class="kpi-source-card-title">${s.icon} ${s.name}</div>
      <div class="kpi-source-tags">
        ${s.tags.map(t => '<span class="kpi-source-tag">' + t + '</span>').join('')}
        <span class="kpi-source-tag note">${s.formula_tag}</span>
      </div>
      <a class="kpi-source-link" href="${linkUrl}" target="_blank">${linkLabel} →</a>
    </div>`;
  }).join('');

  // 計算式
  document.getElementById('kpi-popup-formula').textContent = d.formula;

  // 補足
  const noteWrap = document.getElementById('kpi-popup-note-wrap');
  const noteEl   = document.getElementById('kpi-popup-note');
  if (d.note) {
    noteEl.textContent = d.note;
    noteWrap.style.display = '';
  } else {
    noteWrap.style.display = 'none';
  }

  document.getElementById('kpi-popup-overlay').classList.add('show');
}

function closeKpiPopup(e) {
  if (e.target === document.getElementById('kpi-popup-overlay')) {
    document.getElementById('kpi-popup-overlay').classList.remove('show');
  }
}

window.addEventListener('load', init);
</script>
</body>
</html>
