async function api(type, params={}) {
  const url = new URL(GAS_URL);
  url.searchParams.set('type', type);
  Object.entries(params).forEach(([k,v]) => url.searchParams.set(k, v));
  const res = await fetch(url.toString());
  if (!res.ok) throw new Error('HTTP ' + res.status);
  return res.json();
}

// 数値フォーマット（羅盤）
function fmtN(n) { return n==null?'—':Math.round(n).toLocaleString('ja-JP'); }

// 数値フォーマット（帳簿：通貨切替対応）
function fmtV(n) {
  if (n==null) return '—';
  return Math.round(n).toLocaleString('ja-JP');
}

function v(n) { return n==null ? 0 : n; }
function pct(r) { return r==null?'—':(r*100).toFixed(1)+'%'; }

function loading(msg) {
  document.getElementById('load-msg').textContent = msg||'読み込み中...';
  document.getElementById('overlay').classList.remove('hidden');
}
function hideLoading() { document.getElementById('overlay').classList.add('hidden'); }
function showErr(msg) {
  const el = document.getElementById('err');
  el.textContent = '⚠ ' + msg; el.style.display='block';
  console.error(msg);
}

